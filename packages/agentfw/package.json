{
  "name": "@openguardrails/agentfw",
  "version": "0.5.1",
  "description": "The local firewall for AI agents: route and repair them, and keep your secrets off the model, the API relay, and the supply chain. Local credential masking, per-route model routing, and security detectors on the wire. Free and fully open source.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openguardrails/agentfw.git",
    "directory": "packages/agentfw"
  },
  "homepage": "https://github.com/openguardrails/agentfw",
  "bin": {
    "agentfw": "dist/bin/agentfw.js",
    "agentfw-tap": "dist/bin/tap.js",
    "agentfw-tools": "dist/bin/tools.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "jsonc-parser": "^3.3.1"
  },
  "files": [
    "dist",
    "ui-dist",
    "LICENSE",
    "README.md",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "agentfw": "node --experimental-transform-types ./src/bin/agentfw.ts",
    "daemon": "node --experimental-transform-types ./src/bin/agentfw.ts daemon",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node ./scripts/smoke-test.mjs",
    "prepack": "cp ../../LICENSE ../../README.md ../../PRIVACY.md . && npm run ui:build --prefix ../.. && npm run build"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@praha/byethrow": "^0.5.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "commander": "^14.0.0",
    "drizzle-orm": "^0.36.0",
    "eventsource-parser": "^3.0.0",
    "hono": "^4.6.0",
    "jsonc-parser": "^3.3.1",
    "nanoid": "^5.0.0",
    "tsdown": "^0.10.0",
    "typescript": "^5.7.0",
    "valibot": "^1.0.0",
    "vitest": "^3.2.6",
    "yaml": "^2.6.0"
  }
}
